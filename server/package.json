{
  "name": "aniston-project-hub-server",
  "version": "1.1.0",
  "description": "Backend API for Aniston Project Hub - a full-stack project management application",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "dev": "nodemon server.js",
    "db:sync": "node config/sync.js",
    "db:sync:force": "node config/sync.js --force",
    "cleanup:plan:dry": "node cleanup-plan-data.js --dry-run",
    "cleanup:plan:execute": "node cleanup-plan-data.js --execute",
    "test": "jest --forceExit --detectOpenHandles",
    "test:coverage": "jest --coverage --forceExit --detectOpenHandles",
    "test:watch": "jest --watch"
  },
  "keywords": [
    "project-management",
    "express",
    "sequelize",
    "postgresql",
    "socket.io"
  ],
  "author": "Aniston Technologies",
  "license": "ISC",
  "dependencies": {
    "axios": "^1.7.2",
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "express-rate-limit": "^8.3.1",
    "express-validator": "^7.1.0",
    "helmet": "^7.1.0",
    "jsonwebtoken": "^9.0.2",
    "morgan": "^1.10.0",
    "multer": "^1.4.5-lts.1",
    "node-cron": "^4.2.1",
    "pdfkit": "^0.17.2",
    "pg": "^8.12.0",
    "pg-hstore": "^2.3.4",
    "sequelize": "^6.37.3",
    "socket.io": "^4.7.5",
    "web-push": "^3.6.7",
    "winston": "^3.19.0",
    "ws": "^8.20.0",
    "xss": "^1.0.15"
  },
  "devDependencies": {
    "@types/jest": "^30.0.0",
    "jest": "^30.3.0",
    "nodemon": "^3.1.14",
    "supertest": "^7.2.2"
  }
}
