# ─── Server ───────────────────────────────────────────────────
PORT=5000
NODE_ENV=development

# ─── Client ───────────────────────────────────────────────────
CLIENT_URL=http://localhost:3000

# ─── PostgreSQL Database ─────────────────────────────────────
DB_HOST=localhost
DB_PORT=5432
DB_NAME=aniston_project_hub
DB_USER=postgres
DB_PASSWORD=your_db_password_here

# ─── JWT Authentication ──────────────────────────────────────
JWT_SECRET=your_super_secret_jwt_key_change_this_in_production
JWT_EXPIRES_IN=7d

# ─── Microsoft Teams Webhook ─────────────────────────────────
TEAMS_WEBHOOK_URL=https://outlook.office.com/webhook/your-webhook-url-here

# ─── Microsoft Teams Calendar Integration (Azure AD App) ─────
# NOTE: Azure AD credentials can now be configured from the admin UI (Integrations page).
# These env vars serve as a fallback if no DB config exists.
TEAMS_CLIENT_ID=your_azure_app_client_id
TEAMS_CLIENT_SECRET=your_azure_app_client_secret
TEAMS_TENANT_ID=your_azure_tenant_id_or_common
TEAMS_REDIRECT_URI=http://localhost:5000/api/teams/callback
TEAMS_SSO_REDIRECT_URI=http://localhost:5000/api/auth/microsoft/callback
# Production: Set both URIs to https://monday.anistonav.com/api/... and register them in Azure AD

# ─── Encryption Key (for storing Azure AD secrets in DB) ─────
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ENCRYPTION_KEY=

# ─── AWS S3 (optional - for cloud file storage) ──────────────
AWS_ACCESS_KEY_ID=your_aws_access_key
AWS_SECRET_ACCESS_KEY=your_aws_secret_key
AWS_REGION=us-east-1
AWS_S3_BUCKET=aniston-project-hub-uploads

# ─── File Uploads / Storage ──────────────────────────────────
# Provider: local | s3 | cloudinary  (only "local" is implemented now)
STORAGE_PROVIDER=local
MAX_FILE_SIZE=26214400
UPLOAD_DIR=uploads

# Future S3 config (uncomment when STORAGE_PROVIDER=s3)
# S3_BUCKET=aniston-uploads
# S3_REGION=us-east-1
# S3_ACCESS_KEY_ID=
# S3_SECRET_ACCESS_KEY=

# Future Cloudinary config (uncomment when STORAGE_PROVIDER=cloudinary)
# CLOUDINARY_CLOUD_NAME=
# CLOUDINARY_API_KEY=
# CLOUDINARY_API_SECRET=

# ─── Push Notifications (VAPID) ──────────────────────────────
# Generate with: npx web-push generate-vapid-keys
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:admin@aniston.com

# ─── Webhook API Key (for n8n / external integrations) ───────
# Generate a strong key: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
WEBHOOK_API_KEY=

# ─── Webhook HMAC Signing (D-3 — replay protection + body integrity) ──────
# In addition to WEBHOOK_API_KEY (auth), inbound /api/webhooks/* requests
# can carry an HMAC-SHA256 signature so we can detect replays + tampering.
#
# Sender side computes:
#   X-Aniston-Timestamp: <unix-seconds>
#   X-Aniston-Signature: sha256=<hex of HMAC_SHA256(WEBHOOK_HMAC_SECRET, "<timestamp>.<rawBody>")>
#
# Replay window is ±5 minutes (server clock vs. signed timestamp).
#
# Mode toggle (default `off`):
#   off    — accept everything, ignore signatures (back-compat default).
#   warn   — log a warning when an unsigned request arrives so ops can
#            chase down un-migrated senders, but accept it.
#   strict — reject any request without a valid signature (401).
#
# Migration sequence:
#   1. Set WEBHOOK_HMAC_SECRET, leave WEBHOOK_REQUIRE_SIGNATURE=off, deploy.
#   2. Update each sender (n8n, Teams Outgoing Webhook, etc.) to sign.
#   3. Flip to `warn`, monitor logs for any remaining unsigned senders.
#   4. Once logs are clean for a few days, flip to `strict`.
WEBHOOK_HMAC_SECRET=
WEBHOOK_REQUIRE_SIGNATURE=off

# ─── Content Security Policy (D-8) ───────────────────────────────────────
# Default: report-only. The browser sends violation reports to
# /api/csp-report (logged server-side as `[CSP] violation: ...`) but does
# NOT block anything. Watch the logs for unexpected sources, then flip:
#
#   CSP_ENFORCE=true
#
# to switch to a real Content-Security-Policy enforcement header.
#
# Adjust directives in server/server.js if you load resources from new
# external origins (CDN scripts, image hosts, fonts, etc.).
CSP_ENFORCE=false

# ─── External HRMS API Key ────────────────────────────────────
# Generate a strong key: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
HRMS_API_KEY=


# ─── Tier-1 Database Backup Management ────────────────────────────────────
# Daily automated database dumps to a persistent volume, plus operator-driven
# manual / restore / upload flows behind /api/admin/backups (Tier 1 only).
#
#   DB_BACKUP_ENABLED   Set to "false" to disable the daily cron entirely
#                       (the on-demand API endpoints still work). Default on.
#   DB_BACKUP_CRON      Cron expression for the daily run. Default 0 18 * * *
#                       (6:00 PM server time). Use https://crontab.guru if
#                       changing.
#   DB_BACKUP_DIR       Filesystem root for all backup artefacts inside the
#                       backend container. Must point at a mounted volume
#                       (see docker-compose `backup_data` volume) so files
#                       survive container restarts. Default /app/backups.
#                       Three subdirs are auto-created: database/,
#                       pre-restore/, uploads-inbox/.
#   DB_BACKUP_RETENTION_DAYS
#                       Auto-prune SCHEDULED backups older than N days
#                       after each successful run. Manual / uploaded /
#                       pre_restore backups are NEVER auto-pruned.
#                       Default 30.
#   DB_BACKUP_UPLOAD_MAX_MB
#                       Max accepted .sql.gz upload size (MB). Default 2048.
#   DB_BACKUP_TIMEOUT_MS
#                       Hard ceiling per backup run. The pg_dump pipeline
#                       is killed (SIGTERM → SIGKILL after 5 s grace) and
#                       the row marked failed if it exceeds this. Default
#                       600000 (10 min) in dev, 1800000 (30 min) in prod.
#   PG_DUMP_BIN, PSQL_BIN, GZIP_BIN, GUNZIP_BIN
#                       Override only if the container ships these in a
#                       non-standard location.
#   DB_BACKUP_VIA_DOCKER
#                       LOCAL DEV ONLY. If pg_dump / psql aren't installed
#                       on your host PATH but Postgres is running in a
#                       Docker container, set this to the container name
#                       (e.g. "aniston-postgres" or "aph-postgres-dev").
#                       The backend will shell every pg_dump / psql call
#                       through `docker exec` into that container.
#                       Leave UNSET in production — the backend image
#                       installs postgresql16-client directly.
# Dev tip: leave DB_BACKUP_DIR unset to fall back to <repo>/backups (the
# previous /app/backups default resolved to C:\app\backups on Windows and
# needed admin rights to create).
DB_BACKUP_ENABLED=true
DB_BACKUP_CRON=0 18 * * *
# DB_BACKUP_DIR=/app/backups             # prod default; leave unset in dev
# DB_BACKUP_VIA_DOCKER=aniston-postgres  # dev only — see note above
DB_BACKUP_RETENTION_DAYS=30
DB_BACKUP_UPLOAD_MAX_MB=2048
