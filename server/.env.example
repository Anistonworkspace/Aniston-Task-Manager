# ─── Server ───────────────────────────────────────────────────
PORT=5000
NODE_ENV=development

# ─── Client ───────────────────────────────────────────────────
CLIENT_URL=http://localhost:3000

# ─── PostgreSQL Database ─────────────────────────────────────
DB_HOST=localhost
DB_PORT=5432
DB_NAME=aniston_project_hub
DB_USER=postgres
DB_PASSWORD=your_db_password_here

# ─── JWT Authentication ──────────────────────────────────────
JWT_SECRET=your_super_secret_jwt_key_change_this_in_production
JWT_EXPIRES_IN=7d

# ─── Microsoft Teams Webhook ─────────────────────────────────
TEAMS_WEBHOOK_URL=https://outlook.office.com/webhook/your-webhook-url-here

# ─── Microsoft Teams Calendar Integration (Azure AD App) ─────
# NOTE: Azure AD credentials can now be configured from the admin UI (Integrations page).
# These env vars serve as a fallback if no DB config exists.
TEAMS_CLIENT_ID=your_azure_app_client_id
TEAMS_CLIENT_SECRET=your_azure_app_client_secret
TEAMS_TENANT_ID=your_azure_tenant_id_or_common
TEAMS_REDIRECT_URI=http://localhost:5000/api/teams/callback
TEAMS_SSO_REDIRECT_URI=http://localhost:5000/api/auth/microsoft/callback
# Production: Set both URIs to https://monday.anistonav.com/api/... and register them in Azure AD

# ─── Encryption Key (for storing Azure AD secrets in DB) ─────
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ENCRYPTION_KEY=

# ─── AWS S3 (optional - for cloud file storage) ──────────────
AWS_ACCESS_KEY_ID=your_aws_access_key
AWS_SECRET_ACCESS_KEY=your_aws_secret_key
AWS_REGION=us-east-1
AWS_S3_BUCKET=aniston-project-hub-uploads

# ─── File Uploads / Storage ──────────────────────────────────
# Provider: local | s3 | cloudinary  (only "local" is implemented now)
STORAGE_PROVIDER=local
MAX_FILE_SIZE=26214400
UPLOAD_DIR=uploads

# Future S3 config (uncomment when STORAGE_PROVIDER=s3)
# S3_BUCKET=aniston-uploads
# S3_REGION=us-east-1
# S3_ACCESS_KEY_ID=
# S3_SECRET_ACCESS_KEY=

# Future Cloudinary config (uncomment when STORAGE_PROVIDER=cloudinary)
# CLOUDINARY_CLOUD_NAME=
# CLOUDINARY_API_KEY=
# CLOUDINARY_API_SECRET=

# ─── Push Notifications (VAPID) ──────────────────────────────
# Generate with: npx web-push generate-vapid-keys
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:admin@aniston.com

# ─── Webhook API Key (for n8n / external integrations) ───────
# Generate a strong key: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
WEBHOOK_API_KEY=

# ─── External HRMS API Key ────────────────────────────────────
# Generate a strong key: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
HRMS_API_KEY=
