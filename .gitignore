node_modules/
dist/
build/
.env
*.pem
aws-config.txt
server/uploads/*
!server/uploads/.gitkeep
# Jest / vitest coverage output — re-generated by `npm test --coverage`,
# never source.
server/coverage/
client/coverage/
coverage/

# Slice 9 (OTA enablement): the desktop installer + manifest live under
# server/downloads/desktop/ and MUST be present in the production image
# for /api/desktop/{manifest,download} to return 200. Before slice 9 the
# entire directory was gitignored, which silently broke OTA in
# production (CI's `git reset --hard origin/main` + docker build never
# included the binary). We now commit the published artefacts so the
# next deploy carries them automatically.
#
# Trade-off: each release adds ~80 MB to git history. At ~12 releases/yr
# that is ~1 GB/yr — acceptable for company-scale internal distribution.
# If release cadence grows or installer balloons, migrate to a Docker
# named volume (mount `server/downloads/desktop` as a volume in
# deploy/docker-compose.yml) and re-add the gitignore rules — the
# backend controllers + publish script need NO changes for that
# migration, only deploy config.
#
# Local-build scratch directories that should NEVER be committed.
server/downloads/desktop/*.tmp
server/downloads/desktop/*.partial
server/downloads/desktop/staging/
.DS_Store
*.log
.claude/
.playwright-mcp/

# Debugging screenshots / images at the repo root only.
# Root-anchored so legitimate assets under client/public/icons/, client/src/assets/,
# server/uploads/ etc. are NOT affected. (Already-tracked PNGs are unaffected by gitignore.)
/*.png
/*.jpg
/*.jpeg
/*.gif
/*.webp
screenshots/
debug-screenshots/

# Environment files - never commit
# Belt-and-braces beyond the top-level `.env` rule: explicit per-directory
# entries protect against an editor's "save as .env in subfolder" autocomplete
# accident, and the *.local variants catch developer-only overrides.
.env
.env.local
.env.*.local
server/.env
deploy/.env
*.pem
*.p12
*.key

# Local auth/test capture artefacts — these are produced by curl/MCP login
# automation and CAN contain a live session cookie, JWT, or credentials.
# They were previously un-ignored, so a stray `git add -A` after a successful
# login would silently stage a real session token. Never commit them.
cookies.txt
*.cookies
*.cookie-jar
login.json
server/login.json

# Database dumps — never commit. `backups/` is already ignored; these rules
# additionally protect any dump written elsewhere in the tree (deploy/backups,
# repo root, ad-hoc pg_dump output). Dumps contain password hashes and tokens.
*.sql.gz
*.dump
deploy/backups/

# Phase 4.2 — Stryker mutation-testing artefacts. Re-generated by
# `cd server && npm run test:mutation`. Ignore both the report dir and
# the tmp scratch the test runner forks into.
server/reports/
server/.stryker-tmp/

# Phase 4.3 — Playwright artefacts. Reports + traces + screenshots are
# regenerated per run; only the test source under e2e/ is tracked.
playwright-report/
test-results/
e2e/.auth/
e2e/screenshots/
