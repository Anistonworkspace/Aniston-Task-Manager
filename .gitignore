node_modules/
dist/
build/
.env
*.pem
aws-config.txt
server/uploads/*
!server/uploads/.gitkeep

# Slice 5b: desktop installer + generated manifest are large/dynamic and
# get populated by `npm run desktop:publish` from the build host. Keep the
# directory tracked via .gitkeep so the controller's existsSync path is
# valid in a fresh clone, but never commit the EXE or manifest themselves.
server/downloads/desktop/*
!server/downloads/desktop/.gitkeep
.DS_Store
*.log
.claude/
.playwright-mcp/

# Debugging screenshots / images at the repo root only.
# Root-anchored so legitimate assets under client/public/icons/, client/src/assets/,
# server/uploads/ etc. are NOT affected. (Already-tracked PNGs are unaffected by gitignore.)
/*.png
/*.jpg
/*.jpeg
/*.gif
/*.webp
screenshots/
debug-screenshots/

# Environment files - never commit
# Belt-and-braces beyond the top-level `.env` rule: explicit per-directory
# entries protect against an editor's "save as .env in subfolder" autocomplete
# accident, and the *.local variants catch developer-only overrides.
.env
.env.local
.env.*.local
server/.env
deploy/.env
*.pem
*.p12
*.key
