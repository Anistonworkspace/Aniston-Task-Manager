# ═══════════════════════════════════════════════════════════════
# Aniston Project Hub — Production Environment Variables
# Copy this file to deploy/.env and fill in the values
# ═══════════════════════════════════════════════════════════════

# ─── Database ─────────────────────────────────────────────────
DB_USER=postgres
DB_PASSWORD=CHANGE_ME_TO_STRONG_PASSWORD

# ─── JWT Authentication ───────────────────────────────────────
# Generate with: openssl rand -base64 48
JWT_SECRET=CHANGE_ME_GENERATE_WITH_OPENSSL

# ─── Client URL (your domain) ────────────────────────────────
CLIENT_URL=https://monday.anistonav.com

# ─── Microsoft Teams Integration ──────────────────────────────
TEAMS_CLIENT_ID=
TEAMS_CLIENT_SECRET=
TEAMS_TENANT_ID=
TEAMS_REDIRECT_URI=https://monday.anistonav.com/api/teams/callback
TEAMS_WEBHOOK_URL=

# ─── Push Notifications (VAPID) ──────────────────────────────
# Generate with: npx web-push generate-vapid-keys
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:admin@anistonav.com

# ─── File Uploads ─────────────────────────────────────────────
MAX_FILE_SIZE=26214400
UPLOAD_DIR=uploads

# ─── One-Time Data Cleanup (Director Plan & Time Plan) ───────
# Set BOTH variables to trigger cleanup on next deploy/restart.
# Remove both after successful cleanup to prevent re-runs.
# RUN_PLAN_DATA_CLEANUP=true
# PLAN_DATA_CLEANUP_CONFIRM=YES_DELETE_PLAN_DATA
