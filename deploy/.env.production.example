# ═══════════════════════════════════════════════════════════════
# Aniston Project Hub — Production Environment Variables
# Copy this file to deploy/.env and fill in the values
# ═══════════════════════════════════════════════════════════════

# ─── Database ─────────────────────────────────────────────────
DB_USER=postgres
DB_PASSWORD=CHANGE_ME_TO_STRONG_PASSWORD

# ─── JWT Authentication ───────────────────────────────────────
# Generate with: openssl rand -base64 48
JWT_SECRET=CHANGE_ME_GENERATE_WITH_OPENSSL

# ─── Client URL (your domain) ────────────────────────────────
CLIENT_URL=https://monday.anistonav.com

# ─── Microsoft Teams Integration ──────────────────────────────
TEAMS_CLIENT_ID=
TEAMS_CLIENT_SECRET=
TEAMS_TENANT_ID=
TEAMS_REDIRECT_URI=https://monday.anistonav.com/api/teams/callback
TEAMS_SSO_REDIRECT_URI=https://monday.anistonav.com/api/auth/microsoft/callback
TEAMS_WEBHOOK_URL=

# ─── Encryption Key (for storing Azure AD secrets in DB) ─────
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ENCRYPTION_KEY=CHANGE_ME_GENERATE_WITH_NODE_CRYPTO

# ─── Push Notifications (VAPID) ──────────────────────────────
# Generate with: npx web-push generate-vapid-keys
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:admin@anistonav.com

# ─── File Uploads ─────────────────────────────────────────────
MAX_FILE_SIZE=26214400
UPLOAD_DIR=uploads

# ─── Webhook API Key (for n8n / external integrations) ───────
# Generate a strong key:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
WEBHOOK_API_KEY=CHANGE_ME_GENERATE_WITH_NODE_CRYPTO

# ─── Webhook HMAC Signing (replay protection + body integrity) ───────
# Production should require signed webhooks. After every sender has been
# migrated and observed in `warn` mode, leave this at `strict`.
#   off    — accept everything (not for production).
#   warn   — log unsigned senders but accept (use during migration).
#   strict — reject unsigned/invalid (PRODUCTION DEFAULT).
WEBHOOK_HMAC_SECRET=CHANGE_ME_GENERATE_WITH_NODE_CRYPTO
WEBHOOK_REQUIRE_SIGNATURE=strict

# ─── Content Security Policy ─────────────────────────────────
# Production should enforce CSP after an observation window in report-only.
# Watch /api/csp-report logs in staging; once clean, set this to true.
CSP_ENFORCE=true

# ─── External HRMS API Key ────────────────────────────────────
# Generate a strong key:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
HRMS_API_KEY=CHANGE_ME_GENERATE_WITH_NODE_CRYPTO

# ─── One-Time Password Reset Script ──────────────────────────
# Optional. TTL (in hours) for one-time reset tokens issued by
# deploy/run-onetime-password-reset.sh. Default is 4 if unset.
# ONETIME_RESET_TTL_HOURS=4

# ─── One-Time Data Cleanup (Director Plan & Time Plan) ───────
# Set BOTH variables to trigger cleanup on next deploy/restart.
# Remove both after successful cleanup to prevent re-runs.
# RUN_PLAN_DATA_CLEANUP=true
# PLAN_DATA_CLEANUP_CONFIRM=YES_DELETE_PLAN_DATA
