{
  "name": "aniston-project-hub",
  "version": "1.1.0",
  "description": "Project Management Platform for Aniston Technologies LLP",
  "private": true,
  "scripts": {
    "install:all": "cd server && npm install && cd ../client && npm install",
    "dev:server": "cd server && npm run dev",
    "dev:client": "cd client && npm run dev",
    "dev": "concurrently \"npm run dev:server\" \"npm run dev:client\"",
    "build": "cd client && npm run build",
    "build:desktop": "cd client && npm run build -- --mode desktop",
    "desktop:install": "cd desktop && npm install",
    "desktop:dev": "cd desktop && npm start",
    "desktop:dist": "npm run build:desktop && cd desktop && npm run dist:win",
    "desktop:publish": "node scripts/publish-desktop-installer.js",
    "start": "cd server && npm start",
    "db:sync": "cd server && npm run db:sync",
    "docker:dev": "cd deploy && docker-compose -f docker-compose.dev.yml up -d",
    "docker:prod": "cd deploy && docker-compose up -d --build",
    "docker:down": "cd deploy && docker-compose down",
    "e2e": "playwright test",
    "e2e:ui": "playwright test --ui",
    "e2e:debug": "playwright test --debug",
    "e2e:install-browsers": "playwright install --with-deps chromium"
  },
  "devDependencies": {
    "@playwright/test": "^1.60.0",
    "concurrently": "^10.0.1"
  }
}
